@model TwoFactorAuthenticationViewModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-3">
            <partial name="_ManageNav" />
        </div>
        <div class="col-lg-7">
            <h3>Two-Factor Authentication</h3>
            <partial name="_StatusMessage" />

            <div class="card card-body shadow-sm mb-3">
                <dl class="row mb-0">
                    <dt class="col-sm-5">2FA enabled</dt>
                    <dd class="col-sm-7">@(Model.IsTwoFactorEnabled ? "Yes" : "No")</dd>

                    <dt class="col-sm-5">Authenticator configured</dt>
                    <dd class="col-sm-7">@(Model.HasAuthenticator ? "Yes" : "No")</dd>

                    <dt class="col-sm-5">Recovery codes left</dt>
                    <dd class="col-sm-7">@Model.RecoveryCodesLeft</dd>

                    <dt class="col-sm-5">Browser remembered</dt>
                    <dd class="col-sm-7">@(Model.IsMachineRemembered ? "Yes" : "No")</dd>
                </dl>
            </div>

            <div class="d-flex flex-wrap gap-2">
                @if (!Model.HasAuthenticator)
                {
                    <a asp-action="EnableAuthenticator" class="btn btn-primary">Set up authenticator app</a>
                }
                else if (!Model.IsTwoFactorEnabled)
                {
                    <a asp-action="EnableAuthenticator" class="btn btn-primary">Enable authenticator</a>
                }
                else
                {
                    <a asp-action="GenerateRecoveryCodes" class="btn btn-outline-primary">Generate recovery codes</a>
                    <a asp-action="ResetAuthenticator" class="btn btn-outline-secondary">Reset authenticator key</a>
                    <a asp-action="Disable2fa" class="btn btn-outline-danger">Disable 2FA</a>
                }
            </div>

            @if (Model.IsMachineRemembered)
            {
                <form asp-action="ForgetBrowser" method="post" class="mt-3">
                    <button type="submit" class="btn btn-warning">Forget this browser</button>
                </form>
            }
        </div>
    </div>
</div>
