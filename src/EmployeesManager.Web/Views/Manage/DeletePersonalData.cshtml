@model DeletePersonalDataViewModel
@{
    ViewData["Title"] = "Delete Account";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-3">
            <partial name="_ManageNav" />
        </div>
        <div class="col-lg-7">
            <h3>Delete Account</h3>
            <div class="alert alert-danger">
                Deleting your account is permanent and cannot be undone.
            </div>

            <form asp-action="DeletePersonalData" method="post" class="card card-body shadow-sm">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (Model.HasPassword)
                {
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete account</button>
                    <a asp-action="PersonalData" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
