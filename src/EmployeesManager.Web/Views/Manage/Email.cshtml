@model ManageEmailViewModel
@{
    ViewData["Title"] = "Email";
    var returnUrl = Convert.ToString(ViewData["ReturnUrl"]);
}

<div class="row">
    <div class="col-lg-3">
        <div class="mt-2">
            <partial name="_ManageNav" />
        </div>
    </div>
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4 mt-2">
            <div>
                <h2 class="fw-bold mb-0 text-dark">Email Settings</h2>
                <p class="text-muted mb-0">Manage email confirmation and request email address changes</p>
            </div>
        </div>

        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-envelope-open-text me-2"></i> Email Preferences</h4>
            </div>
            <div class="card-body p-4 p-md-5">
            <partial name="_StatusMessage" />

                <div class="mb-4">
                    <label class="form-label fw-semibold">Current email</label>
                    <input class="form-control" value="@Model.Email" disabled />
                </div>

                @if (Model.IsEmailConfirmed)
                {
                    <div class="alert alert-success py-2 mb-4">Your email is confirmed.</div>
                }
                else
                {
                    <div class="alert alert-warning py-2 mb-3">Your email is not confirmed.</div>
                    <form asp-action="SendVerificationEmail" method="post" class="mb-4">
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button class="btn btn-outline-secondary" type="submit">
                            <i class="fa-solid fa-paper-plane me-2"></i>Send verification email
                        </button>
                    </form>
                }

                <hr />

                <form asp-action="ChangeEmail" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.NewEmail" class="form-label fw-semibold"></label>
                        <input asp-for="Input.NewEmail" class="form-control" />
                        <span asp-validation-for="Input.NewEmail" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-end mt-4 border-top pt-4">
                        <button type="submit" class="btn btn-primary btn-save">
                            <i class="fa-solid fa-envelope-circle-check me-2"></i>Send change email link
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
