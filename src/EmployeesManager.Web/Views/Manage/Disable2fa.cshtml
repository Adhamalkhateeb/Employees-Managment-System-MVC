@{
    ViewData["Title"] = "Disable 2FA";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-3">
            <partial name="_ManageNav" />
        </div>
        <div class="col-lg-7">
            <h3>Disable Two-Factor Authentication</h3>
            <partial name="_StatusMessage" />

            <div class="card card-body shadow-sm">
                <div class="alert alert-warning">Disabling 2FA reduces account security.</div>

                <form asp-action="Disable2fa" method="post" class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Disable 2FA</button>
                    <a asp-action="TwoFactorAuthentication" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
