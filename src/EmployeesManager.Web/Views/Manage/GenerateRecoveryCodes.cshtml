@{
    ViewData["Title"] = "Generate Recovery Codes";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-3">
            <partial name="_ManageNav" />
        </div>
        <div class="col-lg-7">
            <h3>Generate Recovery Codes</h3>
            <partial name="_StatusMessage" />

            <div class="card card-body shadow-sm">
                <div class="alert alert-warning">
                    Generating new recovery codes will invalidate your previous recovery codes.
                </div>

                <form asp-action="GenerateRecoveryCodes" method="post" class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Generate new codes</button>
                    <a asp-action="TwoFactorAuthentication" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
