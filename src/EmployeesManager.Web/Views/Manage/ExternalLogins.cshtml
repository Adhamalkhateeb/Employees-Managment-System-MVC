@model ExternalLoginsViewModel
@{
    ViewData["Title"] = "External logins";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-3">
            <partial name="_ManageNav" />
        </div>
        <div class="col-lg-7">
            <h3>External logins</h3>
            <partial name="_StatusMessage" />

            @if (Model.CurrentLogins.Count > 0)
            {
                <div class="card card-body shadow-sm mb-3">
                    <h5>Registered logins</h5>
                    <table class="table mb-0">
                        <tbody>
                            @foreach (var login in Model.CurrentLogins)
                            {
                                <tr>
                                    <td>@login.ProviderDisplayName</td>
                                    <td class="text-end">
                                        @if (Model.ShowRemoveButton)
                                        {
                                            <form asp-action="RemoveExternalLogin" method="post" class="d-inline">
                                                <input type="hidden" name="loginProvider" value="@login.LoginProvider" />
                                                <input type="hidden" name="providerKey" value="@login.ProviderKey" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (Model.OtherLogins.Count > 0)
            {
                <div class="card card-body shadow-sm">
                    <h5>Add another service</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var provider in Model.OtherLogins)
                        {
                            <form asp-action="LinkExternalLogin" method="post">
                                <button
                                    type="submit"
                                    class="btn btn-outline-primary"
                                    name="provider"
                                    value="@provider.Name">
                                    @provider.DisplayName
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }

            @if (Model.CurrentLogins.Count == 0 && Model.OtherLogins.Count == 0)
            {
                <div class="card card-body shadow-sm">
                    <p class="mb-0 text-muted">No external login providers are configured for this application.</p>
                </div>
            }
        </div>
    </div>
</div>
