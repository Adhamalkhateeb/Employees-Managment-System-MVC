@model CreateEmployeeRequest
@{ ViewBag.Title = "Create Employee"; }

<style>
    .form-card {
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        border: none;
    }
    .form-card .card-header {
        background: linear-gradient(135deg, #198754, #146c43);
        color: white;
        border-bottom: none;
        padding: 1.5rem;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #198754;
        font-weight: 500;
    }
    .form-control {
        border-radius: 8px;
        border: 1px solid #dee2e6;
        padding: 1rem 0.75rem;
    }
    .form-control:focus {
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
        border-color: #198754;
    }
    .btn-create {
        transition: all 0.3s ease;
        border-radius: 8px;
        padding: 0.6rem 2rem;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(25, 135, 84, 0.2);
    }
    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(25, 135, 84, 0.3);
    }
    .btn-cancel {
        border-radius: 8px;
        padding: 0.6rem 2rem;
        font-weight: 500;
    }
    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #495057;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e9ecef;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
        <div class="d-flex align-items-center mb-4 mt-2">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle me-3 shadow-sm" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Add New Employee</h2>
                <p class="text-muted mb-0">Fill in the details to add an employee to the directory</p>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger shadow-sm border-0 rounded-4 mb-4">
                <div class="d-flex">
                    <i class="fa-solid fa-circle-exclamation fs-4 me-3 text-danger mt-1"></i>
                    <div>
                        <h5 class="alert-heading fw-bold mb-1">Validation Errors</h5>
                        <div asp-validation-summary="All" class="mb-0 text-danger"></div>
                    </div>
                </div>
            </div>
        }

        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-user-plus me-2"></i> Employee Details</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <h5 class="section-title"><i class="fa-regular fa-id-card me-2"></i>Personal Information</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                                <label asp-for="FirstName">First Name</label>
                                <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="MiddleName" class="form-control" placeholder="Middle Name" />
                                <label asp-for="MiddleName">Middle Name</label>
                                <span asp-validation-for="MiddleName" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                                <label asp-for="LastName">Last Name</label>
                                <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="DateOfBirth" type="date" class="form-control" placeholder="Date of Birth" />
                                <label asp-for="DateOfBirth">Date of Birth</label>
                                <span asp-validation-for="DateOfBirth" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>

                    <h5 class="section-title"><i class="fa-solid fa-address-book me-2"></i>Contact Details</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                                <label asp-for="PhoneNumber">Phone Number</label>
                                <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="EmailAddress" class="form-control" placeholder="Email Address" />
                                <label asp-for="EmailAddress">Email Address</label>
                                <span asp-validation-for="EmailAddress" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-floating">
                                <input asp-for="Address" class="form-control" placeholder="Address" />
                                <label asp-for="Address">Address</label>
                                <span asp-validation-for="Address" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Country" class="form-control" placeholder="Country" />
                                <label asp-for="Country">Country</label>
                                <span asp-validation-for="Country" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>

                    <h5 class="section-title"><i class="fa-solid fa-building-user me-2"></i>Employment Details</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Department" class="form-control" placeholder="Department" />
                                <label asp-for="Department">Department</label>
                                <span asp-validation-for="Department" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Designation" class="form-control" placeholder="Designation" />
                                <label asp-for="Designation">Designation</label>
                                <span asp-validation-for="Designation" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-5 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light btn-cancel">Cancel</a>
                        <button type="submit" class="btn btn-success btn-create"><i class="fa-solid fa-check me-2"></i>Create Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
