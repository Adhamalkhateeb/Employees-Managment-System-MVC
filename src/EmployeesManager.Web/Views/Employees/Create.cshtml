@model CreateEmployeeRequest
@{ ViewBag.Title = "Create Employee"; }

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-10 col-xl-8">
        <div class="d-flex align-items-center mb-4 mt-2">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle me-3 shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Add New Employee</h2>
                <p class="text-muted mb-0">Fill in the details to add an employee to the directory</p>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger shadow-sm border-0 rounded-4 mb-4">
                <div class="d-flex">
                    <i class="fa-solid fa-circle-exclamation fs-4 me-3 text-danger mt-1"></i>
                    <div>
                        <h5 class="alert-heading fw-bold mb-1">Validation Errors</h5>
                        <div asp-validation-summary="All" class="mb-0 text-danger"></div>
                    </div>
                </div>
            </div>
        }

        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-user-plus me-2"></i> Employee Details</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <h5 class="section-title"><i class="fa-regular fa-id-card me-2"></i>Personal Information</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">  
                             <label asp-for="FirstName" class="form-label fw-semibold">First Name</label>
                                <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                                <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4">
                                <label asp-for="MiddleName" class="form-label fw-semibold">Middle Name</label>
                                <input asp-for="MiddleName" class="form-control" placeholder="Middle Name" />
                                
                                <span asp-validation-for="MiddleName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4">
                             <label asp-for="LastName" class="form-label fw-semibold">Last Name</label>
                                <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                                <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                             <label asp-for="DateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" placeholder="Date of Birth" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <h5 class="section-title"><i class="fa-solid fa-address-book me-2"></i>Contact Details</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                             <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                              <label asp-for="EmailAddress" class="form-label fw-semibold">Email Address</label>
                                <input asp-for="EmailAddress" class="form-control" placeholder="Email Address" />
                                <span asp-validation-for="EmailAddress" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-12">
                                <label asp-for="Address" class="form-label fw-semibold">Address</label>
                                <input asp-for="Address" class="form-control" placeholder="Address" />
                                <span asp-validation-for="Address" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CountryId" class="form-label fw-semibold">Country</label>
                            <select asp-for="CountryId" asp-items="ViewBag.Countries" class="form-select">
                                <option value="">Select Country</option>
                            </select>
                            <span asp-validation-for="CountryId" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <h5 class="section-title"><i class="fa-solid fa-building-user me-2"></i>Employment Details</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label fw-semibold">Department</label>
                            <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select">
                                <option value="">Select Department</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DesignationId" class="form-label fw-semibold">Designation</label>
                            <select asp-for="DesignationId" asp-items="ViewBag.Designations" class="form-select">
                                <option value="">Select Designation</option>
                            </select>
                            <span asp-validation-for="DesignationId" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-5 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light btn-cancel">Cancel</a>
                        <button type="submit" class="btn btn-success btn-create"><i class="fa-solid fa-check me-2"></i>Create Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
