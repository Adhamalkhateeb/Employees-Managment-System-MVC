@model EmployeeResponse
@{ ViewBag.Title = "Employee Details"; }

<div class="row justify-content-center mt-4">
    <div class="col-lg-10 col-xl-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit btn-sm px-3 rounded-pill shadow-sm">
                    <i class="fa-solid fa-pen me-2"></i>Edit
                </a>
            </div>
        </div>

        <div class="card details-card mb-5">
            <div class="card-header">
                <div class="avatar-wrapper">
                    <div class="avatar-circle">
                        @(string.IsNullOrWhiteSpace(Model.FullName) ? "?" : Model.FullName[0].ToString().ToUpper())
                    </div>
                </div>
                <div class="header-content">
                    <h2 class="mb-1 fw-bold">@Model.FullName</h2>
                    <p class="mb-0 opacity-75"><i class="fa-solid fa-briefcase me-2"></i>@(string.IsNullOrEmpty(Model.DesignationName) ? "Employee" : Model.DesignationName)</p>
                </div>
            </div>
            <div class="card-body pt-5 px-4 pb-4 px-md-5">
                
                <div class="row g-4 mt-2">
                    <div class="col-md-6">
                        <div class="info-section">
                            <h5 class="mb-4 text-primary fw-bold border-bottom pb-2"><i class="fa-regular fa-address-card me-2"></i>Personal Info</h5>
                            
                            <span class="info-label">Employee Number</span>
                            <div class="info-value"><span class="badge bg-secondary">@Model.EmployeeNumber</span></div>
                            
                            <span class="info-label">Full Name</span>
                            <div class="info-value">@Model.FullName</div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="info-section">
                            <h5 class="mb-4 text-primary fw-bold border-bottom pb-2"><i class="fa-solid fa-address-book me-2"></i>Contact Details</h5>
                            
                            <span class="info-label">Email Address</span>
                            <div class="info-value">
                                <a href="mailto:@Model.EmailAddress" class="text-decoration-none text-body">
                                    <i class="fa-solid fa-envelope text-primary me-2"></i>@Model.EmailAddress
                                </a>
                            </div>
                            
                            <span class="info-label">Phone Number</span>
                            <div class="info-value">
                                <a href="tel:@Model.PhoneNumber" class="text-decoration-none text-body">
                                    <i class="fa-solid fa-phone text-success me-2"></i>@Model.PhoneNumber
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 mt-4">
                        <div class="info-section">
                            <h5 class="mb-4 text-primary fw-bold border-bottom pb-2"><i class="fa-solid fa-building me-2"></i>Company Details</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <span class="info-label">Department</span>
                                    <div class="info-value">@(string.IsNullOrEmpty(Model.DepartmentName) ? "N/A" : Model.DepartmentName)</div>
                                </div>
                                <div class="col-md-6">
                                    <span class="info-label">Designation</span>
                                    <div class="info-value">@(string.IsNullOrEmpty(Model.DesignationName) ? "N/A" : Model.DesignationName)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
