@model EmployeeResponse
@{ ViewBag.Title = "Delete Employee"; }

<style>
    .delete-card {
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(220,53,69,0.15);
        border: none;
        overflow: hidden;
    }
    .delete-card .card-header {
        background: linear-gradient(135deg, #dc3545, #b02a37);
        color: white;
        border-bottom: none;
        padding: 1.5rem;
    }
    .info-list dt {
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }
    .info-list dd {
        font-size: 1.1rem;
        color: #212529;
        font-weight: 500;
        margin-bottom: 1.2rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px dashed #e9ecef;
    }

    .btn-delete {
        transition: all 0.3s ease;
        border-radius: 8px;
        padding: 0.6rem 2rem;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(220,53,69,0.3);
    }
    .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(220,53,69,0.4);
    }
    .btn-cancel {
        border-radius: 8px;
        padding: 0.6rem 2rem;
        font-weight: 500;
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
    }
</style>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4 mt-2">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle me-3 shadow-sm" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Delete Employee</h2>
                <p class="text-muted mb-0">Review before permanently removing</p>
            </div>
        </div>

        <div class="card delete-card mb-5">
            <div class="card-header text-center py-4">
                <h4 class="card-title fw-bold m-0 d-block">Confirm Deletion</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                
                <div class="alert alert-danger bg-opacity-10 text-danger border-0 rounded-3 mb-4 text-center">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> Are you sure you want to delete this employee record?
                </div>

                <div class="px-md-4">
                    <dl class="row info-list mb-0">
                        <dt class="col-sm-4 text-sm-end">Employee No.</dt>
                        <dd class="col-sm-8"><span class="badge bg-secondary">@Model.EmployeeNumber</span></dd>

                        <dt class="col-sm-4 text-sm-end">Full Name</dt>
                        <dd class="col-sm-8">@Model.FullName</dd>

                        <dt class="col-sm-4 text-sm-end">Email</dt>
                        <dd class="col-sm-8"><a href="mailto:@Model.EmailAddress" class="text-decoration-none text-primary">@Model.EmailAddress</a></dd>
</dl>
                </div>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-5 border-top pt-4 text-center">
    @Html.AntiForgeryToken()
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-cancel">No, Keep It</a>
                        <button type="submit" class="btn btn-danger btn-delete text-white"><i class="fa-solid fa-trash me-2"></i>Yes, Delete Record</button>
                    </div>
</form>
