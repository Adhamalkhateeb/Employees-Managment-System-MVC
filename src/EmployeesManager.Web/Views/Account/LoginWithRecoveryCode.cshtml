@model LoginWithRecoveryCodeRequest
@{
    ViewData["Title"] = "Recovery Code Sign In";
    var returnUrl = Convert.ToString(ViewData["ReturnUrl"]);
}

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-6 col-xl-5">
        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-key me-2"></i> Recovery Code Sign In</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <p class="text-muted mb-4">Enter one of your account recovery codes to sign in.</p>

                <form asp-action="LoginWithRecoveryCode" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="RecoveryCode" class="form-label fw-semibold"></label>
                        <input asp-for="RecoveryCode" class="form-control" autocomplete="off" />
                        <span asp-validation-for="RecoveryCode" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mt-4 border-top pt-4">
                        <a asp-action="Login" asp-route-returnUrl="@returnUrl">Back to login</a>
                        <button type="submit" class="btn btn-primary btn-save">
                            <i class="fa-solid fa-right-to-bracket me-2"></i>Sign in
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
