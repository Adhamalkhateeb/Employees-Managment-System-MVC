@{
    ViewData["Title"] = "Account Locked";
}

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-7 col-xl-6">
        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-lock me-2"></i> Account Locked</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <div class="alert alert-warning mb-4">
                    <h5 class="alert-heading fw-bold">Account temporarily locked</h5>
                    <p class="mb-0">Too many failed sign-in attempts were detected. Please wait a few minutes and try again.</p>
                </div>

                <a class="btn btn-primary btn-primary-elevated" asp-action="Login">Back to login</a>
            </div>
        </div>
    </div>
</div>
