@{
    ViewData["Title"] = "Account Locked";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card shadow-sm text-center">
            <div class="card-body p-4 p-lg-5">
                <i class="bi bi-lock-fill display-1 text-warning mb-3"></i>
                <h1 class="fw-bold">@ViewData["Title"]</h1>
                <p class="text-muted fs-5">Your account has been temporarily locked due to multiple failed login attempts.</p>

                <div class="alert alert-warning my-4">
                    <h5 class="alert-heading fw-bold">Please Wait</h5>
                    <p class="mb-0">For your security, this account has been locked. Please try again in a few minutes.</p>
                </div>

                <div class="d-grid">
                    <a class="btn btn-primary btn-lg" asp-action="Login">
                        <i class="bi bi-arrow-left me-2"></i>Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
