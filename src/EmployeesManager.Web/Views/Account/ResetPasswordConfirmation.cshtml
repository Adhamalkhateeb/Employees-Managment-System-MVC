@{
    ViewData["Title"] = "Password Reset Complete";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card shadow-sm text-center">
            <div class="card-body p-4 p-lg-5">
                <i class="bi bi-check-circle-fill display-1 text-success mb-3"></i>
                <h1 class="fw-bold">@ViewData["Title"]</h1>
                <p class="text-muted fs-5">Your password has been successfully updated.</p>

                <div class="alert alert-success my-4">
                    <h5 class="alert-heading fw-bold">Success!</h5>
                    <p class="mb-0">You can now use your new password to sign in to your account.</p>
                </div>

                <div class="d-grid">
                    <a class="btn btn-primary btn-lg" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Proceed to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
