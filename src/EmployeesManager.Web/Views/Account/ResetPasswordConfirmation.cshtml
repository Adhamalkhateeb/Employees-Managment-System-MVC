@{
    ViewData["Title"] = "Password Reset Complete";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="alert alert-success mb-3">
                        <h4 class="alert-heading">Password updated</h4>
                        <p class="mb-0">Your password has been reset successfully. You can now sign in.</p>
                    </div>

                    <a class="btn btn-primary" asp-action="Login">Go to login</a>
                </div>
            </div>
        </div>
    </div>
</div>
