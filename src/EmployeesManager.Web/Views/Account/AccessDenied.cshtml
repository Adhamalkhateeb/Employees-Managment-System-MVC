@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card shadow-sm text-center">
            <div class="card-body p-4 p-lg-5">
                <i class="bi bi-slash-circle-fill display-1 text-danger mb-3"></i>
                <h1 class="fw-bold">@ViewData["Title"]</h1>
                <p class="text-muted fs-5">You do not have permission to view this page.</p>

                <div class="alert alert-danger my-4">
                    <h5 class="alert-heading fw-bold">Unauthorized Access</h5>
                    <p class="mb-0">Contact your system administrator if you believe this is an error.</p>
                </div>

                <div class="d-grid">
                    <a class="btn btn-primary btn-lg" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-fill me-2"></i>Return to Homepage
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
