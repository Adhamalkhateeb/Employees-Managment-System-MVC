@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-7 col-xl-6">
        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-ban me-2"></i> Access Denied</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <div class="alert alert-warning mb-4">
                    <h5 class="alert-heading fw-bold">Access denied</h5>
                    <p class="mb-0">You do not have permission to access this resource.</p>
                </div>

                <a class="btn btn-primary btn-primary-elevated" asp-controller="Home" asp-action="Index">Back to home</a>
            </div>
        </div>
    </div>
</div>
