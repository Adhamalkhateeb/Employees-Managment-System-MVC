@model string
@{
    ViewData["Title"] = "Password Reset Link Sent";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card shadow-sm text-center">
            <div class="card-body p-4 p-lg-5">
                <i class="bi bi-envelope-paper-heart-fill display-1 text-info mb-3"></i>
                <h1 class="fw-bold">@ViewData["Title"]</h1>
                <p class="text-muted fs-5">Please check your email for a link to reset your password.</p>

                <div class="alert alert-info my-4">
                    <h5 class="alert-heading fw-bold">Check Your Inbox</h5>
                    <p class="mb-0">If an account exists for <strong>@Model</strong>, you will receive an email with instructions on how to reset your password.</p>
                </div>

                <div class="d-grid">
                    <a class="btn btn-primary btn-lg" asp-action="Login">
                        <i class="bi bi-arrow-left me-2"></i>Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
