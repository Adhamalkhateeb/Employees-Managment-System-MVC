@model ForgotPasswordRequest
@{
    ViewData["Title"] = "Forgot Your Password?";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-xl-5">
        <div class="text-center mb-4">
            <h1 class="fw-bold">@ViewData["Title"]</h1>
            <p class="text-muted">Enter your email address and we will send you a link to reset your password.</p>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4 p-lg-5">
                <h4 class="card-title text-center fw-semibold mb-4"><i class="bi bi-envelope-fill me-2"></i>Reset Password</h4>
                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger alert alert-danger p-2 mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" autocomplete="email" />
                        <label asp-for="Email"></label>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-send-fill me-2"></i>Send Password Reset Link
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light border-0 py-3 px-4 px-lg-5">
                <div class="text-center">
                    <a asp-action="Login"><i class="bi bi-arrow-left me-2"></i>Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
