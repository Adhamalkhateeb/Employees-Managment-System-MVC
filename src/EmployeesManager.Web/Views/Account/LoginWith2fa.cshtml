@model LoginWith2faRequest
@{
    ViewData["Title"] = "Two-Factor Authentication";
    var returnUrl = Convert.ToString(ViewData["ReturnUrl"]);
    var rememberMe = Convert.ToBoolean(ViewData["RememberMe"]);
}

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-6 col-xl-5">
        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-shield-halved me-2"></i> Two-Factor Sign In</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <p class="text-muted mb-4">Enter the verification code from your authenticator app.</p>

                <form asp-action="LoginWith2fa" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <input type="hidden" name="rememberMe" value="@rememberMe" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="TwoFactorCode" class="form-label fw-semibold"></label>
                        <input asp-for="TwoFactorCode" class="form-control" autocomplete="one-time-code" />
                        <span asp-validation-for="TwoFactorCode" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMachine" class="form-check-input" />
                        <label asp-for="RememberMachine" class="form-check-label"></label>
                    </div>

                    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                        <a asp-action="LoginWithRecoveryCode" asp-route-returnUrl="@returnUrl">Use a recovery code</a>
                        <button type="submit" class="btn btn-primary btn-save">
                            <i class="fa-solid fa-right-to-bracket me-2"></i>Sign in
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
