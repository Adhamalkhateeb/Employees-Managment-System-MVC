@model string
@{
    ViewData["Title"] = "Confirm Your Email";
    var returnUrl = Convert.ToString(ViewData["ReturnUrl"]);
    var statusMessage = TempData["StatusMessage"] as string;
}

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-7 col-xl-6">
        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-envelope-circle-check me-2"></i> Confirm Your Email</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <div class="alert alert-info mb-4">@statusMessage</div>
                }

                <div class="alert alert-success mb-4">
                    <h5 class="alert-heading fw-bold">Registration successful</h5>
                    <p class="mb-2">A confirmation link has been generated for <strong>@Model</strong>.</p>
                    <p class="mb-0">Open your mailbox and click the link to activate your account before signing in.</p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary btn-primary-elevated" asp-action="Login" asp-route-returnUrl="@returnUrl">
                        <i class="fa-solid fa-right-to-bracket me-2"></i>Go to login
                    </a>
                    <a class="btn btn-outline-secondary" asp-action="ResendEmailConfirmation" asp-route-email="@Model" asp-route-returnUrl="@returnUrl">
                        Resend confirmation
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
