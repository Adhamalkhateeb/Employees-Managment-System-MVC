@model string
@{
    ViewData["Title"] = "Confirm Your Email";
    var statusMessage = TempData["StatusMessage"] as string;
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card shadow-sm text-center">
            <div class="card-body p-4 p-lg-5">
                <i class="bi bi-envelope-check-fill display-1 text-success mb-3"></i>
                <h1 class="fw-bold">@ViewData["Title"]</h1>
                <p class="text-muted fs-5">Please check your email to confirm your account.</p>

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <div class="alert alert-info my-4">@statusMessage</div>
                }

                <div class="alert alert-success my-4">
                    <h5 class="alert-heading fw-bold">Registration Successful!</h5>
                    <p class="mb-2">A confirmation link has been sent to <strong>@Model</strong>.</p>
                    <p class="mb-0">Please click the link in the email to activate your account before signing in.</p>
                </div>

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a class="btn btn-primary btn-lg px-4 gap-3" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Go to Login
                    </a>
                    <a class="btn btn-outline-secondary btn-lg px-4" asp-action="ResendEmailConfirmation" asp-route-email="@Model">
                        Resend Email
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
