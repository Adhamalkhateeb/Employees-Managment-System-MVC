@model LoginRequest
@{
    ViewData["Title"] = "Login";
    var returnUrl = Convert.ToString(ViewData["ReturnUrl"]);
}

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-6 col-xl-5">
        <div class="d-flex align-items-center mb-4 mt-2">
            <div>
                <h2 class="fw-bold mb-0 text-dark">Welcome Back</h2>
                <p class="text-muted mb-0">Sign in to continue to Employees Manager</p>
            </div>
        </div>

        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-right-to-bracket me-2"></i> Sign In</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-save">
                        <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>Sign In
                    </button>
                </form>
            </div>
            <div class="card-footer bg-white border-0 pt-0 pb-4 px-4 px-md-5">
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <span class="text-muted">Need an account?</span>
                    <a asp-action="Register" asp-route-returnUrl="@returnUrl">Create one</a>
                    <span class="text-muted ms-md-3">Need another confirmation email?</span>
                    <a asp-action="ResendEmailConfirmation" asp-route-returnUrl="@returnUrl">Resend email</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
