@model ResendEmailConfirmationRequest
@{
    ViewData["Title"] = "Resend Email Confirmation";
    var returnUrl = Convert.ToString(ViewData["ReturnUrl"]);
}

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-6 col-xl-5">
        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-paper-plane me-2"></i> Resend Confirmation Email</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <p class="text-muted mb-4">Enter your account email and we will send a new confirmation link.</p>

                <form asp-action="ResendEmailConfirmation" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4 border-top pt-4">
                        <a asp-action="Login" asp-route-returnUrl="@returnUrl" class="btn btn-light btn-cancel">Back to login</a>
                        <button type="submit" class="btn btn-primary btn-save">
                            <i class="fa-solid fa-envelope me-2"></i>Send email
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
