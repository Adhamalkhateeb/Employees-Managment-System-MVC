@model DesignationResponse
@{ ViewBag.Title = "Designation Details"; }

<div class="row justify-content-center mt-4">
    <div class="col-lg-8 col-xl-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit btn-sm px-3 rounded-pill shadow-sm">
                <i class="fa-solid fa-pen me-2"></i>Edit
            </a>
        </div>

        <div class="card details-card mb-5">
            <div class="card-header">
                <div class="avatar-wrapper">
                    <div class="avatar-circle">
                        @(string.IsNullOrWhiteSpace(Model.Name) ? "?" : Model.Name[0].ToString().ToUpper())
                    </div>
                </div>
                <div class="header-content">
                    <h2 class="mb-1 fw-bold">@Model.Name</h2>
                    <p class="mb-0 opacity-75"><i class="fa-solid fa-id-badge me-2"></i>Designation Record</p>
                </div>
            </div>

            <div class="card-body pt-5 px-4 pb-4 px-md-5">
                <div class="info-section">
                    <h5 class="mb-4 text-primary fw-bold border-bottom pb-2">
                        <i class="fa-regular fa-address-card me-2"></i>Record Info
                    </h5>

                    <span class="info-label">Designation Name</span>
                    <div class="info-value">@Model.Name</div>
                </div>
            </div>
        </div>
    </div>
</div>
