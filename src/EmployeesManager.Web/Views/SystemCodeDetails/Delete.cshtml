@using EmployeesManager.Contracts.Responses.SystemCodeDetails
@model SystemCodeDetailResponse
@{ ViewBag.Title = "Delete SystemCodeDetail"; }

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4 mt-2">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle me-3 shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Delete System Code Detail</h2>
                <p class="text-muted mb-0">Review before permanently removing</p>
            </div>
        </div>

        <div class="card delete-card mb-5">
            <div class="card-header text-center py-4">
                <h4 class="card-title fw-bold m-0 d-block">Confirm Deletion</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <div class="alert alert-danger bg-opacity-10 text-danger border-0 rounded-3 mb-4 text-center">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> Are you sure you want to delete this system code detail record?
                </div>

                <div class="px-md-4">
                    <dl class="row info-list mb-0">
                        <dt class="col-sm-4 text-sm-end">System Code</dt>
                        <dd class="col-sm-8">@Model.SystemCodeName</dd>

                        <dt class="col-sm-4 text-sm-end">Code</dt>
                        <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Code</span></dd>

                        <dt class="col-sm-4 text-sm-end">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        <dt class="col-sm-4 text-sm-end">Order</dt>
                        <dd class="col-sm-8">@(Model.OrderNo?.ToString() ?? "-")</dd>
                    </dl>
                </div>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-5 border-top pt-4 text-center">
                    @Html.AntiForgeryToken()
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-cancel">No, Keep It</a>
                        <button type="submit" class="btn btn-danger btn-delete text-white"><i class="fa-solid fa-trash me-2"></i>Yes, Delete Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
