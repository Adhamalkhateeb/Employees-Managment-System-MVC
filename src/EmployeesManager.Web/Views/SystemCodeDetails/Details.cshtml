@model SystemCodeDetailResponse
@{ ViewBag.Title = "System Code Detail"; }

<div class="row justify-content-center mt-4">
    <div class="col-lg-8 col-xl-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit btn-sm px-3 rounded-pill shadow-sm">
                <i class="fa-solid fa-pen me-2"></i>Edit
            </a>
        </div>

        <div class="card details-card mb-5">
            <div class="card-header">
                <div class="avatar-wrapper">
                    <div class="avatar-circle">
                        @(string.IsNullOrWhiteSpace(Model.Code) ? "?" : Model.SystemCode[0].ToString().ToUpper())
                    </div>
                </div>
                <div class="header-content">
                    <h2 class="mb-1 fw-bold">@Model.Description</h2>
                    <p class="mb-0 opacity-75"><i class="fa-solid fa-list-check me-2"></i>System Code Detail Record</p>
                </div>
            </div>

            <div class="card-body pt-5 px-4 pb-4 px-md-5">
                <div class="info-section">
                    <h5 class="mb-4 text-primary fw-bold border-bottom pb-2">
                        <i class="fa-regular fa-address-card me-2"></i>Record Info
                    </h5>

                                    <span class="info-label">System Code</span>
                    <div class="info-value"><span>@Model.SystemCode</span></div>

                    <span class="info-label">Code</span>
                    <div class="info-value"><span class="badge bg-secondary">@Model.Code</span></div>

    

                    <span class="info-label">Description</span>
                    <div class="info-value">@(Model.Description ?? "N/A")</div>

                    <span class="info-label">Order</span>
                    <div class="info-value">@(Model.OrderNo?.ToString() ?? "N/A")</div>
                </div>
            </div>
        </div>
    </div>
</div>
