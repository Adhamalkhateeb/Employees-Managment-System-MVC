@model CreateSystemCodeDetailRequest
@{ ViewBag.Title = "Create System Code Detail"; }

<div class="row justify-content-center crud-form-page">
    <div class="col-lg-8 col-xl-6">
        <div class="d-flex align-items-center mb-4 mt-2">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle me-3 shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Add System Code Detail</h2>
                <p class="text-muted mb-0">Create a detail value under a system code</p>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger shadow-sm border-0 rounded-4 mb-4">
                <div asp-validation-summary="All" class="mb-0 text-danger"></div>
            </div>
        }

        <div class="card form-card mb-5">
            <div class="card-header">
                <h4 class="card-title fw-bold m-0"><i class="fa-solid fa-list-check me-2"></i> Detail Information</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="SystemCodeId" class="form-label fw-semibold">System Code</label>
                            <select asp-for="SystemCodeId" asp-items="ViewBag.SystemCodes" class="form-select">
                                <option value="">Select System Code</option>
                            </select>
                            <span asp-validation-for="SystemCodeId" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label fw-semibold">Code</label>
                            <input asp-for="Code" class="form-control" />
                            <span asp-validation-for="Code" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OrderNo" class="form-label fw-semibold">Order Number</label>
                            <input asp-for="OrderNo" class="form-control" />
                            <span asp-validation-for="OrderNo" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light btn-cancel">Cancel</a>
                        <button type="submit" class="btn btn-success btn-create">
                            <i class="fa-solid fa-check me-2"></i>Create Detail
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
