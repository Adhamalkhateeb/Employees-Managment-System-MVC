@using EmployeesManager.Contracts.Responses.LeaveApplications
@model LeaveApplicationResponse
@{
    ViewData["Title"] = "Delete Leave Application";
}

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="card-title">@ViewData["Title"]</h3>
            <a asp-action="Index" class="btn btn-light">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
    <div class="card-body">
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Are you sure you want to delete this leave application record? This action cannot be undone.
        </div>

        <dl class="row">
            <dt class="col-sm-3">Employee</dt>
            <dd class="col-sm-9">@Model.EmployeeName</dd>

            <dt class="col-sm-3">Leave Type</dt>
            <dd class="col-sm-9">@Model.LeaveTypeName</dd>

            <dt class="col-sm-3">Duration</dt>
            <dd class="col-sm-9">@Model.DurationName</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.Status</span></dd>

            <dt class="col-sm-3">Period</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy") - @Model.EndDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">Days</dt>
            <dd class="col-sm-9">@Model.Days day(s)</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-light">Cancel</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash-fill"></i> Delete Record
                </button>
            </div>
        </form>
    </div>
</div>
