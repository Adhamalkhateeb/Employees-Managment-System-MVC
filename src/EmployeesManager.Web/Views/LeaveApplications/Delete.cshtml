@{ ViewBag.Title = "Delete Leave Application"; }

<div class="row justify-content-center mt-4">
    <div class="col-md-10 col-lg-8">
        <div class="d-flex align-items-center mb-4 mt-2">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle me-3 shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0 ">Delete Leave Application</h2>
                <p class="text-muted mb-0">Review before permanently removing</p>
            </div>
        </div>

        <div class="card delete-card mb-5">
            <div class="card-header text-center py-4">
                <h4 class="card-title fw-bold m-0 d-block">Confirm Deletion</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <div class="alert alert-danger bg-opacity-10 text-danger border-0 rounded-3 mb-4 text-center">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> Are you sure you want to delete this leave application record?
                </div>

                <div class="px-md-4">
                    <dl class="row info-list mb-0">
                        <dt class="col-sm-4 text-sm-end">Employee</dt>
                        <dd class="col-sm-8">@Model.EmployeeName</dd>

                        <dt class="col-sm-4 text-sm-end">Leave Type</dt>
                        <dd class="col-sm-8">@Model.LeaveTypeName</dd>

                        <dt class="col-sm-4 text-sm-end">Duration</dt>
                        <dd class="col-sm-8">@Model.DurationName</dd>

                        <dt class="col-sm-4 text-sm-end">Status</dt>
                        <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Status</span></dd>

                        <dt class="col-sm-4 text-sm-end">Period</dt>
                        <dd class="col-sm-8">@Model.StartDate.ToString("dd MMM yyyy") - @Model.EndDate.ToString("dd MMM yyyy")</dd>

                        <dt class="col-sm-4 text-sm-end">Days</dt>
                        <dd class="col-sm-8">@Model.Days day(s)</dd>

                        <dt class="col-sm-4 text-sm-end">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        @if (!string.IsNullOrWhiteSpace(Model.Attachment))
                        {
                            <dt class="col-sm-4 text-sm-end">Attachment</dt>
