@using EmployeesManager.Contracts.Responses.LeaveApplications
@model LeaveApplicationResponse
@{ ViewBag.Title = "Delete Leave Application"; }

<h2>Delete Leave Application</h2>

<div class="alert alert-warning">Are you sure you want to delete this leave application?</div>

<dl class="row">
    <dt class="col-sm-3">Employee</dt>
    <dd class="col-sm-9">@Model.EmployeeName</dd>

    <dt class="col-sm-3">Leave Type</dt>
    <dd class="col-sm-9">@Model.LeaveTypeName</dd>

    <dt class="col-sm-3">Duration</dt>
    <dd class="col-sm-9">@Model.DurationName</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.StatusName</dd>

    <dt class="col-sm-3">Period</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy") - @Model.EndDate.ToString("dd MMM yyyy")</dd>

    <dt class="col-sm-3">Days</dt>
    <dd class="col-sm-9">@Model.Days</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    @if (!string.IsNullOrWhiteSpace(Model.Attachment))
    {
        <dt class="col-sm-3">Attachment</dt>
        <dd class="col-sm-9">@Model.Attachment</dd>
    }
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
