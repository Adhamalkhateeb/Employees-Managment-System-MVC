@using EmployeesManager.Contracts.Responses.LeaveApplications
@model List<LeaveApplicationResponse>
@{ ViewBag.Title = "Leave Applications"; }

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="fw-bold mb-0 text-dark">Leave Applications</h2>
        <p class="text-muted mb-0">Track requests, durations, and approval status</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-primary-elevated px-4 py-2">
        <i class="fa-solid fa-plus me-2"></i>New Application
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-light text-center p-5 shadow-sm rounded-4 border-0" role="alert">
        <h4 class="text-dark fw-bold">No Leave Applications Found</h4>
        <p class="text-muted mb-4">Start by creating your first leave application.</p>
        <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3">Add Application</a>
    </div>
}
else
{
    <div class="card list-card mb-5">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title fw-bold m-0"><i class="fa-solid fa-list-check me-2"></i> Application Analysis</h3>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-modern mb-0 align-middle js-data-table">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4 text-uppercase border-0 table-head-label">Employee</th>
                            <th class="text-uppercase border-0 table-head-label">Type</th>
                            <th class="text-uppercase border-0 table-head-label">Duration</th>
                            <th class="text-uppercase border-0 table-head-label">Period</th>
                            <th class="text-uppercase border-0 table-head-label">Days</th>
                            <th class="text-uppercase border-0 table-head-label">Status</th>
                            <th class="text-uppercase border-0 table-head-label">Approved By</th>
                            <th class="text-center text-uppercase border-0 table-head-label">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@item.EmployeeName</td>
                                <td>@item.LeaveTypeName</td>
                                <td>@item.DurationName</td>
                                <td>@item.StartDate.ToString("dd MMM yyyy") - @item.EndDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-secondary">@item.Days day(s)</span></td>
                                <td><span class="badge @GetStatusBadge(item.StatusName)">@item.StatusName</span></td>
                                <td>@(string.IsNullOrWhiteSpace(item.ApprovedBy) ? "-" : item.ApprovedBy)</td>
                                <td>
                                    <div class="d-flex gap-2 justify-content-center">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning action-btn" data-bs-toggle="tooltip" title="Edit">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger action-btn" data-bs-toggle="tooltip" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@functions {
    private static string GetStatusBadge(string status) =>
        status.ToLowerInvariant() switch
        {
            var s when s.Contains("approve") => "bg-success",
            var s when s.Contains("reject") => "bg-danger",
            var s when s.Contains("pending") => "bg-warning text-dark",
            _ => "bg-secondary"
        };
}

@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}
