@functions {
    private static string GetStatusBadge(string status) =>
        status.ToLowerInvariant() switch
        {
            var s when s.Contains("approve") => "bg-success",
            var s when s.Contains("cancel") => "bg-secondary",
            var s when s.Contains("reject") => "bg-danger",
            var s when s.Contains("pending") => "bg-warning ",
            _ => "bg-secondary"
        };

    private static bool IsPendingStatus(string status) =>
        !string.IsNullOrWhiteSpace(status)
        && status.Contains("pending", StringComparison.OrdinalIgnoreCase);
}
