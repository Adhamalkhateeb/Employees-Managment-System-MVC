@model LeaveApplicationResponse
@{
    ViewData["Title"] = "Leave Application Details";
}

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="card-title">@ViewData["Title"]</h3>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-light">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
                @if (ViewBag.IsPendingStatus(Model.Status))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil-fill"></i> Edit
                    </a>
                    <div class="btn-group">
                        <button type="button" class="btn btn-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            Workflow Actions
                        </button>
                        <ul class="dropdown-menu">
                            <li>
                                <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-success"><i class="bi bi-check-circle-fill me-2"></i>Approve</button>
                                </form>
                            </li>
                            <li><a class="dropdown-item text-danger" asp-action="Reject" asp-route-id="@Model.Id"><i class="bi bi-x-circle-fill me-2"></i>Reject</a></li>
                            <li>
                                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-secondary"><i class="bi bi-ban-fill me-2"></i>Cancel</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Employee</dt>
                    <dd class="col-sm-8">@Model.EmployeeName</dd>

                    <dt class="col-sm-4">Leave Type</dt>
                    <dd class="col-sm-8">@Model.LeaveTypeName</dd>

                    <dt class="col-sm-4">Duration</dt>
                    <dd class="col-sm-8">@Model.DurationName</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8"><span class="badge @ViewBag.GetStatusBadge(Model.Status)">@Model.Status</span></dd>

                    <dt class="col-sm-4">Period</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToString("dd MMM yyyy") - @Model.EndDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-4">Days</dt>
                    <dd class="col-sm-8">@Model.Days day(s)</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Attachment</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Attachment) ? "-" : Model.Attachment)</dd>

                    <dt class="col-sm-4">Rejection Reason</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.RejectionReason) ? "-" : Model.RejectionReason)</dd>

                    <dt class="col-sm-4">Approved By</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ApprovedBy) ? "-" : Model.ApprovedBy)</dd>

                    <dt class="col-sm-4">Approved At</dt>
                    <dd class="col-sm-8">@(Model.ApprovedAtUtc?.ToString("dd MMM yyyy hh:mm tt") ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
