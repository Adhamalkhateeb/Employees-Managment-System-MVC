                        >
                            <i class="fa-solid fa-bolt me-2"></i>Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-sm">
                            <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
