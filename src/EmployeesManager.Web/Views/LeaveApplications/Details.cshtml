@model LeaveApplicationResponse
@{ ViewBag.Title = "Leave Application Details"; }

<div class="row justify-content-center mt-4">
    <div class="col-lg-9 col-xl-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-light btn-sm rounded-circle shadow-sm back-circle-btn">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div class="d-flex gap-2">
                @if (IsPendingStatus(Model.Status))
                {
                    <div class="dropdown">
                        <button
                            class="btn btn-outline-primary btn-sm px-3 rounded-pill shadow-sm dropdown-toggle"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                        >
                            <i class="fa-solid fa-bolt me-2"></i>Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-sm">
                            <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-success">
                                    <i class="fa-solid fa-check me-2"></i>Approve
                                </button>
                            </form>

                            <a asp-action="Reject" asp-route-id="@Model.Id" class="dropdown-item text-danger">
                                <i class="fa-solid fa-xmark me-2"></i>Reject
                            </a>

                            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-secondary">
                                    <i class="fa-solid fa-ban me-2"></i>Cancel
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @if (IsPendingStatus(Model.Status))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit btn-sm px-3 rounded-pill shadow-sm">
                        <i class="fa-solid fa-pen me-2"></i>Edit
                    </a>
                }
            </div>
        </div>

        <div class="card details-card mb-5">
            <div class="card-header">
                <div class="avatar-wrapper">
                    <div class="avatar-circle">
                        @(string.IsNullOrWhiteSpace(Model.EmployeeName) ? "?" : Model.EmployeeName[0].ToString().ToUpper())
                    </div>
                </div>
                <div class="header-content">
                    <h2 class="mb-1 fw-bold">@Model.EmployeeName</h2>
                    <p class="mb-0 opacity-75"><i class="fa-solid fa-calendar-check me-2"></i>Leave Application Record</p>
                </div>
            </div>

            <div class="card-body pt-5 px-4 pb-4 px-md-5">
                <div class="info-section">
                    <h5 class="mb-4 text-primary fw-bold border-bottom pb-2">
                        <i class="fa-regular fa-address-card me-2"></i>Application Info
                    </h5>

                    <span class="info-label">Leave Type</span>
                    <div class="info-value">@Model.LeaveTypeName</div>

                    <span class="info-label">Duration</span>
                    <div class="info-value">@Model.DurationName</div>

                    <span class="info-label">Status</span>
                    <div class="info-value"><span class="badge @GetStatusBadge(Model.Status)">@Model.Status</span></div>

                    <span class="info-label">Period</span>
                    <div class="info-value">@Model.StartDate.ToString("dd MMM yyyy") - @Model.EndDate.ToString("dd MMM yyyy")</div>

                    <span class="info-label">Days</span>
                    <div class="info-value">@Model.Days day(s)</div>

                    <span class="info-label">Description</span>
                    <div class="info-value">@Model.Description</div>

                    <span class="info-label">Attachment</span>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.Attachment) ? "-" : Model.Attachment)</div>

                    <span class="info-label">Rejection Reason</span>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.RejectionReason) ? "-" : Model.RejectionReason)</div>

                    <span class="info-label">Approved By</span>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.ApprovedBy) ? "-" : Model.ApprovedBy)</div>

                    <span class="info-label">Approved At</span>
                    <div class="info-value">@(Model.ApprovedAtUtc?.ToString("dd MMM yyyy hh:mm tt") ?? "-")</div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string GetStatusBadge(string status) =>
        status.ToLowerInvariant() switch
        {
            var s when s.Contains("approve") => "bg-success",
            var s when s.Contains("cancel") => "bg-secondary",
            var s when s.Contains("reject") => "bg-danger",
            var s when s.Contains("pending") => "bg-warning ",
            _ => "bg-secondary"
        };

    private static bool IsPendingStatus(string status) =>
        !string.IsNullOrWhiteSpace(status)
        && status.Contains("pending", StringComparison.OrdinalIgnoreCase);
}
