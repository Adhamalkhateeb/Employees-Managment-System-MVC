  <script>
    // this is the script of Theme Toggle (Dark/light mode)
    const themeToggleBtn = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const htmlTag = document.documentElement;
    const sidebar = document.querySelector('.app-sidebar');
    function applyTheme(theme) {
      htmlTag.setAttribute('data-bs-theme', theme);
      localStorage.setItem('theme', theme);
      if (theme === 'dark') {
        themeIcon.classList.replace('bi-moon-stars-fill', 'bi-sun-fill');
        sidebar.setAttribute('data-bs-theme', 'dark');
      } else {
        themeIcon.classList.replace('bi-sun-fill', 'bi-moon-stars-fill');
        sidebar.setAttribute('data-bs-theme', 'light');
      }
    }
    function toggleTheme() {
      const currentTheme = htmlTag.getAttribute('data-bs-theme');
      if (currentTheme === 'dark') {
        applyTheme('light');
      } else {
        applyTheme('dark');
      }
    }
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) {
      applyTheme(savedTheme);
    }
    // Code of save sidebar (open/close)
    function sidebarMode(){
      setTimeout(() => {
        const bodyTag = document.body;
        const bodyclass = bodyTag.getAttribute('class');
        if(bodyTag.classList.contains('sidebar-collapse')){
          localStorage.setItem('sidebar','close')
        }else{
          localStorage.setItem('sidebar','open')
        }
      },50)
    }
    // check if user clicked in any space
    document.addEventListener('click',(event) =>{
      const isToggleButton = event.target.closest('[data-lte-toggle="sidebar"]');
      const isOverlay = event.target.classList.contains('sidebar-overlay');
      if (isToggleButton || isOverlay) {
        setTimeout(() => {
          const bodyTag = document.body;
          if (bodyTag.classList.contains('sidebar-collapse')) {
            localStorage.setItem('sidebar', 'close');
          } else {
            localStorage.setItem('sidebar', 'open');
          }
        }, 50); 
      }
    });
    // check sidebar mode on phone or desktop
    document.addEventListener('DOMContentLoaded', () => {
      const savedSidebar = localStorage.getItem('sidebar');
      const bodyTag = document.body;
      
      const isDesktop = window.innerWidth >= 992;

      if (isDesktop) {

        if (savedSidebar === 'close') {
          bodyTag.classList.add('sidebar-collapse');
        } else {
          bodyTag.classList.remove('sidebar-collapse');
        }
      } else {
        bodyTag.classList.remove('sidebar-open');
        bodyTag.classList.add('sidebar-collapse');
      }
    });
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const setMobileDataLabels = function (table) {
        const headers = Array.from(table.querySelectorAll('thead th')).map(function (header) {
          return (header.textContent || '').trim();
        });

        table.querySelectorAll('tbody tr').forEach(function (row) {
          let cellIndex = 0;
          Array.from(row.children).forEach(function (cell) {
            if (cell.tagName !== 'TD') {
              return;
            }

            const headerText = headers[cellIndex] || '';
            cell.setAttribute('data-label', headerText);
            cellIndex += 1;
          });
        });
      };

      const dataTables = document.querySelectorAll('.js-data-table');

      dataTables.forEach(function (table) {
        setMobileDataLabels(table);

        if (!table.classList.contains('dataTable')) {
          const dt = new DataTable(table, {
            layout: {
              topStart: {}
            }
          });

          dt.on('draw', function () {
            setMobileDataLabels(table);
          });
        }
      });
    });
  </script>
